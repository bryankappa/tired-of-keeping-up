# LLM
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# X / twscrape
TWS_ACCOUNT_USERNAME=
TWS_ACCOUNT_PASSWORD=
TWS_ACCOUNT_EMAIL=
TWS_ACCOUNT_EMAIL_PASSWORD=
TWS_ACCOUNT_COOKIES=
TWS_PROXY=
TWS_ACCOUNTS_DB_PATH=data/twscrape_accounts.db
X_MIN_VIEWS=10000
X_MIN_BOOKMARKS=100
X_ARTICLE_MIN_CHARS=500
X_EXPAND_CANDIDATES_PER_QUERY=5
PRIORITY_AUTHORS=karpathy,trq212,swyx,simonw,latentspacepod
PRIORITY_COMPANIES=openai,anthropic,xai,googledeepmind,gemini,langchainai,baseten,ramp,primalresearch
DIGEST_MAX_ITEMS=3
TWS_ACCOUNT_COOKIES=auth_token=YOUR_AUTH_TOKEN; ct0=YOUR_CT0
# Search strategy
X_SEARCH_QUERIES=article min_faves:100 ("how we built" OR "how we made" OR "what i learned" OR "lessons from" OR "how to") (agents OR "coding agent" OR "Claude Code" OR Codex OR MCP OR sandbox) lang:en||article min_faves:100 ("context engineering" OR "agent harness" OR "tool calling" OR "tool use" OR skills OR architecture) ("Claude Code" OR Codex OR Anthropic OR OpenAI OR agents) lang:en||article min_faves:100 (inference OR serving OR vllm OR sglang OR quantization OR batching OR latency OR throughput) (benchmark OR benchmarks OR architecture OR deployment OR kernels) lang:en||article min_faves:100 (RAG OR retrieval OR reranker OR embeddings OR evals) ("how to" OR architecture OR benchmark OR benchmarks OR implementation) lang:en||article min_faves:100 ("reinforcement learning" OR RLHF OR GRPO OR DPO OR PPO OR "reward model") (training OR evals OR benchmark OR implementation) lang:en||article min_faves:100 (OpenAI OR Anthropic OR xAI OR Gemini OR "Google DeepMind" OR LangChain OR Baseten OR Ramp OR "Primal Research") (agents OR inference OR evals OR deployment OR engineering OR release) lang:en

# Official source discovery and browser-backed X expansion
OFFICIAL_SOURCE_LIMIT=5
OFFICIAL_ARTICLE_MIN_CHARS=600
BROWSER_EXPAND_X=1
PLAYWRIGHT_CLI_PATH=$HOME/.codex/skills/playwright/scripts/playwright_cli.sh
PLAYWRIGHT_HEADED=0
PLAYWRIGHT_TIMEOUT_MS=30000

# Optional delivery bridge if you use OpenClaw or another relay process
OPENCLAW_WEBHOOK_URL=
OPENCLAW_AUTH_TOKEN=
